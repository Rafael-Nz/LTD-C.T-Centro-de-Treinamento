# Habilita o módulo de reescrita de URLs
RewriteEngine On

RewriteBase /ctt/

# 1. Ignorar a pasta de administração
RewriteRule ^admin($|/) - [L]
RewriteRule ^api($|/) - [L]

# Servir arquivos estáticos de public/ de forma segura
RewriteCond %{REQUEST_URI} \.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|pdf|mp4|webm)$ [NC]
RewriteCond %{REQUEST_URI} !^/ctt/public/ [NC]
RewriteRule ^(.+)$ public/$1 [L]

# 2. Não reescrever arquivos e pastas reais
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
